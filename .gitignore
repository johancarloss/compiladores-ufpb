# === Binários compilados ===
*.exe
*.out
compci
compcia
compciv
zeller

# === Objetos e artefatos de build (qualquer lugar) ===
*.o
*.a
*.so

# === Assembly GERADO por compiladores (não confundir com fontes .s) ===
# Os .s em atv*/tests/ são gerados pelo compci da atv02 (output do compilador).
# Já o atv*/zeller.s, atv*/runtime.s etc. são FONTES e devem ser versionados.
atv*/tests/*.s

# === Executáveis e cópias temporárias dentro de atv*/tests/ ===
atv*/tests/runtime.s
atv*/tests/p1
atv*/tests/p2
atv*/tests/erro
atv*/tests/grande
atv*/tests/grande_ok
atv*/tests/overflow
atv*/tests/letras_meio
atv*/tests/negativo
atv*/tests/so_espaco
atv*/tests/vazio

